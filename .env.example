# Database
DATABASE_URL=postgresql://fridgecheck:fridgecheck_dev@localhost:5432/fridgecheck
POSTGRES_PASSWORD=fridgecheck_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT - CHANGE IN PRODUCTION
SECRET_KEY=your-super-secret-key-change-this-in-production

# Environment
ENVIRONMENT=development
DEBUG=true

# Frontend
VITE_API_URL=http://localhost/api/v1

# Anthropic API (for Rescue Recipes AI suggestions)
ANTHROPIC_API_KEY=your-key-here
# Model identifier passed to client.messages.create. Override to roll model
# upgrades without a code change. Current model IDs:
# https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AWS (for production Terraform deployment)
# AWS_REGION=eu-west-1
# AWS_ACCOUNT_ID=123456789012
